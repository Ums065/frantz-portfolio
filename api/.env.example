# ============================================================
# FrantzCoutard.com — API environment template
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Application ---
APP_ENV=local          # local | production
APP_DEBUG=false        # enable only while debugging locally

# --- Database ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=frantz_portfolio
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# --- Session ---
SESSION_NAME=FC_SESSION

# --- CORS ---
# Empty = echo the request Origin (fine for local dev behind the Vite proxy).
# Production: set the exact origin, e.g. https://frantzcoutard.com
CORS_ORIGIN=

# --- SMTP mail (registration verification + notifications) ---
# Used by the registration/email-verification flow and the team notification mailer.
MAIL_FROM_ADDRESS=no-reply@frantzcoutard.com
MAIL_FROM_NAME=FrantzCoutard
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_TIMEOUT_SECONDS=8
MAIL_ALLOW_PHP_FALLBACK=false

# --- Email notifications (Contact / Request forms) ---
# Set MAIL_ENABLED=true and NOTIFY_EMAIL to receive an email when a visitor
# submits the contact or any request form.
MAIL_ENABLED=false
NOTIFY_EMAIL=
