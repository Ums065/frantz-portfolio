# ============================================================
# FrantzCoutard.com — API environment template
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Application ---
APP_ENV=local          # local | production
APP_DEBUG=false        # enable only while debugging locally
APP_URL=https://frantzcoutard.com
FRONTEND_URL=
DEMO_MODE=off          # MUST be off in production (one-click demo login is disabled when off)
EMAIL_VERIFICATION_REQUIRED=false  # set true in production to require verified email before login

# --- Database ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=frantz_portfolio
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# --- Session ---
SESSION_NAME=FC_SESSION

# --- CORS ---
# Empty = echo the request Origin (fine for local dev behind the Vite proxy).
# Production: set the exact origin, e.g. https://frantzcoutard.com
CORS_ORIGIN=

# --- Gmail API mail (recommended) ---
# Fill these after running /api/gmail-oauth-helper.php.
MAIL_PROVIDER=gmail_api
MAIL_FROM_ADDRESS=your-gmail-account@gmail.com
MAIL_FROM_NAME=FrantzCoutard
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
MAIL_VERIFY_PEER=true
MAIL_TIMEOUT_SECONDS=8
MAIL_ALLOW_PHP_FALLBACK=false

# --- Optional SMTP fallback ---
# Only use this block if you want SMTP instead of Gmail API.
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls

# --- Email notifications (Contact / Request forms) ---
# Set MAIL_ENABLED=true and NOTIFY_EMAIL to receive an email when a visitor
# submits the contact or any request form.
MAIL_ENABLED=false
NOTIFY_EMAIL=

# --- Store checkout (Stripe hosted checkout) ---
STRIPE_SECRET_KEY=

# --- Store checkout: Razorpay (client-side modal) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Store checkout: PayPal (Orders v2 approve+capture) ---
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_ENV=sandbox

# --- Store currency (ISO code, lowercase for Stripe) ---
STORE_CURRENCY=usd
