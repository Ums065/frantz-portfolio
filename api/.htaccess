RewriteEngine On

# Route everything (that isn't a real file/dir) to the front controller.
# No hardcoded RewriteBase: relative substitution resolves to this directory,
# so the API works whether mounted at the domain root (/api/) or a subfolder
# (/frantz-portfolio/api/).
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?r=$1 [QSA,L]
