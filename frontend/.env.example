# Frontend environment template (Vite). Copy to `.env`.
# Variables MUST be prefixed with VITE_ to be exposed to the app.

# API base path. Use a root-absolute path (leading slash) so requests resolve to
# /api/... from ANY client-side route, not relative to the current page.
# Production is served at the domain root, so /api is correct. For a subfolder
# deployment, set the full path (e.g. /frantz-portfolio/api).
VITE_API_BASE=/api
