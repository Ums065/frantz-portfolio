# ============================================================
# SPA fallback for the built React app (frontend/dist).
# Vite copies this file into dist/ on `npm run build`.
# It makes client-side routes (/about, /awards, /blog, /events, …)
# work on direct hits and page refresh when Apache serves the build.
# ============================================================
<IfModule mod_rewrite.c>
  RewriteEngine On

  # If you deploy the build under a subfolder instead of the domain root,
  # uncomment and set this (e.g. RewriteBase /frantz-portfolio/frontend/dist/).
  # RewriteBase /

  # Serve real files and directories as-is (JS, CSS, images, uploads…).
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Never hijack API calls (the PHP API is served separately).
  RewriteCond %{REQUEST_URI} ^/api/ [OR]
  RewriteCond %{REQUEST_URI} /api/
  RewriteRule ^ - [L]

  # Everything else → the SPA entry point.
  RewriteRule ^ index.html [L]
</IfModule>

# ============================================================
# Performance: gzip/deflate compression + long-lived caching for
# hashed static assets (Vite fingerprints filenames, so far-future
# caching is safe). Guarded by IfModule so it degrades gracefully.
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript text/javascript
  AddOutputFilterByType DEFLATE application/json application/xml application/rss+xml
  AddOutputFilterByType DEFLATE image/svg+xml application/x-font-ttf font/woff font/woff2
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  # Fingerprinted build assets — cache hard for a year.
  ExpiresByType text/css                "access plus 1 year"
  ExpiresByType application/javascript  "access plus 1 year"
  ExpiresByType text/javascript         "access plus 1 year"
  ExpiresByType image/webp              "access plus 1 year"
  ExpiresByType image/png               "access plus 1 year"
  ExpiresByType image/jpeg              "access plus 1 year"
  ExpiresByType image/svg+xml           "access plus 1 year"
  ExpiresByType font/woff2              "access plus 1 year"
  ExpiresByType font/woff               "access plus 1 year"
  # HTML must revalidate so new deploys are picked up.
  ExpiresByType text/html               "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  # Immutable cache for fingerprinted asset bundles.
  <FilesMatch "\.(?:js|css|woff2?|webp|png|jpe?g|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Always revalidate the SPA shell.
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
