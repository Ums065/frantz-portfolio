# Project root entry point for Apache.
# This serves the built React app from frontend/dist while leaving /api
# requests to the PHP router in api/.

Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Root URL should open the built SPA.
  RewriteRule ^$ frontend/dist/index.html [L]

  # Leave the API alone so api/.htaccess can route it to index.php.
  RewriteRule ^api(/.*)?$ - [L]

  # Clean URL: /partner serves the static Our Partners page.
  RewriteRule ^partner/?$ partner.html [L]

  # Serve build assets from frontend/dist.
  RewriteRule ^assets/(.*)$ frontend/dist/assets/$1 [L]

  # Serve any real file that lives inside the build at the web root
  # (sitemap.xml, robots.txt, favicon, manifest, docs/*, …) — otherwise
  # the SPA fallback below would hand back index.html (HTML) for them,
  # which is why Google Search Console said "Couldn't fetch" the sitemap.
  RewriteCond %{DOCUMENT_ROOT}/frontend/dist%{REQUEST_URI} -f
  RewriteRule ^(.*)$ frontend/dist/$1 [L]

  # Serve real files and folders as-is.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA fallback for client-side routes.
  RewriteRule ^ frontend/dist/index.html [L]
</IfModule>
