# Project root entry point for Apache.
# This serves the built React app from frontend/dist while leaving /api
# requests to the PHP router in api/.

Options -Indexes

# Security (defense in depth): never serve dotfiles or raw config / database /
# backup files anywhere under the web root. api/.htaccess repeats this for the
# API directory. Apache 2.4 syntax.
<FilesMatch "(^\.|\.(env|ini|log|sql|sqlite|db|bak|old|orig|swp|sh)$)">
    Require all denied
</FilesMatch>

# M-4: HTTP security headers (hardening). CSP is intentionally framing-only so it
# cannot break the Razorpay/Stripe/PayPal checkout scripts; a full script-src CSP
# would need to allowlist those providers first.
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Content-Security-Policy "frame-ancestors 'self'"
  # HSTS is honored by browsers only over HTTPS (ignored over plain HTTP), so
  # setting it unconditionally is safe and takes effect once the site is on TLS.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # M-5: force HTTPS in production. Skips localhost / 127.0.0.1 so local WAMP
  # HTTP development is not redirected.
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !=https
  RewriteCond %{HTTP_HOST} !=localhost
  RewriteCond %{HTTP_HOST} !^127\.0\.0\.1
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # Root URL should open the built SPA.
  RewriteRule ^$ frontend/dist/index.html [L]

  # Leave the API alone so api/.htaccess can route it to index.php.
  RewriteRule ^api(/.*)?$ - [L]

  # /partner is now the dynamic React page (falls through to the SPA below).
  # /player keeps serving the static Our Partners snapshot from the build.
  RewriteRule ^player/?$ frontend/dist/partner.html [L]

  # Serve build assets from frontend/dist.
  RewriteRule ^assets/(.*)$ frontend/dist/assets/$1 [L]

  # Serve any real file that lives inside the build at the web root
  # (sitemap.xml, robots.txt, favicon, manifest, docs/*, …) — otherwise
  # the SPA fallback below would hand back index.html (HTML) for them,
  # which is why Google Search Console said "Couldn't fetch" the sitemap.
  RewriteCond %{DOCUMENT_ROOT}/frontend/dist%{REQUEST_URI} -f
  RewriteRule ^(.*)$ frontend/dist/$1 [L]

  # Serve real files and folders as-is.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA fallback for client-side routes.
  RewriteRule ^ frontend/dist/index.html [L]
</IfModule>
